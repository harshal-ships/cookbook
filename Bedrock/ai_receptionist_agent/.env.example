# Telcoflow
WSS_API_KEY=your_telcoflow_api_key
WSS_CONNECTOR_UUID=your_connector_uuid

# AWS Bedrock — Nova 2 Sonic
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
NOVA_MODEL_ID=amazon.nova-2-sonic-v1:0
NOVA_VOICE_ID=matthew
NOVA_ENABLE_TOOLS=true

# Receptionist
COMPANY_NAME=Acme Corp
DEFAULT_PHONE_COUNTRY_CODE=
RECEPTION_CALLS_PATH=reception_calls.json
HANDOFF_AUDIO_GRACE_SECONDS=3

# CRM: json (local demo) or pipedrive
CRM_BACKEND=json
CUSTOMERS_PATH=customers.json
LEADS_PATH=leads.json

# Pipedrive (when CRM_BACKEND=pipedrive)
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_COMPANY_DOMAIN=yourcompany
PIPEDRIVE_LEAD_TITLE_PREFIX=Inbound call

LOG_LEVEL=INFO
