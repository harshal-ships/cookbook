# Telcoflow (inbound voice)
WSS_API_KEY=your_telcoflow_api_key
WSS_CONNECTOR_UUID=your_connector_uuid

# Gemini Live
GOOGLE_API_KEY=your_google_api_key
GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Business hours (Mon–Fri in BUSINESS_TIMEZONE)
BUSINESS_TIMEZONE=Asia/Kolkata
BUSINESS_OPEN_HOUR=9
BUSINESS_CLOSE_HOUR=17

# Telegram team notifications (Bot API — not Slack)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_or_group_id

# Storage
VOICEMAILS_PATH=voicemails.json

# Logging
LOG_LEVEL=INFO
LOG_TRANSCRIPTS=true
