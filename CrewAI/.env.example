# Telcoflow — phone call connectivity
WSS_API_KEY=your_telcoflow_api_key
WSS_CONNECTOR_UUID=your_telcoflow_connector_uuid

# Google API key — Gemini Live (crew_agent.py) and all CrewAI agents
GOOGLE_API_KEY=your_google_api_key

# Amazon Bedrock (crew_bedrock_agent.py) — IAM keys for Nova Sonic 2 streaming
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
